{
	"name": "electrobun-react-tailwind-vite",
	"version": "1.0.0",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"electrobun": "1.18.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.2.1",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.7.2",
		"vite": "^8.0.16"
	}
}
